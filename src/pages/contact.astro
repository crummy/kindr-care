---
import ChatWidget from "@components/ChatWidget.astro";
import Header from "@components/Header.astro";
import Icon from "@components/Icon.astro";
import Modal from "@components/Modal.astro";
import SectionHead from "@components/SectionHead.astro";
import BaseLayout from "@layouts/BaseLayout.astro";
import { crisisSupport } from "@content/site";
---

<BaseLayout
  title="Contact Janet | Kindr"
  description="Reach out directly to Janet Horwell, Matrescence Practitioner at Kindr. Share how you're feeling and let's start the conversation."
>
  <Header />

  <main>
    <section class="why contact-intro">
      <div class="wrap">
        <SectionHead kicker="Reach out directly" title="Get in touch with Janet">
          <p>Whatever's going on, there's no wrong way to start the conversation. Share a little, or a lot, it's up to you.</p>
        </SectionHead>
      </div>
    </section>

    <section class="contact" id="contact">
      <div class="contact-card">
        <form class="contact-form" id="contactForm">
          <div class="form-fields">
            <div>
              <label for="contactName">Name</label>
              <input type="text" id="contactName" placeholder="Your name" required />
            </div>
            <div>
              <label for="contactMessage">Tell me a bit about yourself and where you're currently at</label>
              <textarea id="contactMessage" rows="5" placeholder="Share whatever feels relevant, there's no wrong way to start." required></textarea>
            </div>
            <button class="btn btn-primary btn-block" type="submit">Send to Janet</button>
          </div>
          <div class="modal-success">
            <Icon name="check" />
            <p>Your email app should now be open with your message ready to send to Janet. Once it's sent, she'll be in touch soon.</p>
          </div>
        </form>
      </div>
    </section>

    <section class="crisis">
      <div class="wrap crisis-box">
        <p class="crisis-lead">Kindr is not a crisis support, but if you are in need of urgent support please contact one of the following:</p>
        <ul class="crisis-list">
          {crisisSupport.map((item) => (
            <li><strong>{item.label}:</strong> {item.text}</li>
          ))}
        </ul>
      </div>
    </section>
  </main>

  <footer>
    <div class="wrap">&copy; <span id="year"></span> Kindr. Matrescence Continuity of Care.</div>
  </footer>

  <ChatWidget />
  <Modal />
  <script>
    import "../scripts/site";
  </script>
</BaseLayout>
