---
interface Props {
  name: "heart" | "sparkle" | "leaf" | "person" | "plus" | "circle" | "chat" | "close" | "menu" | "check";
}

const { name } = Astro.props;
---

{
  name === "heart" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 21s-7-4.35-9.5-8.5C.5 9 2 5 6 5c2.2 0 3.7 1.2 4.5 2.4C11.3 6.2 12.8 5 15 5c4 0 5.5 4 3.5 7.5C19 16.65 12 21 12 21Z" fill="currentColor" /></svg>
  )
}
{
  name === "sparkle" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 2l2.4 6.6L21 11l-6.6 2.4L12 20l-2.4-6.6L3 11l6.6-2.4L12 2Z" fill="currentColor" /></svg>
  )
}
{
  name === "leaf" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M12 3c.4 3 .3 5.8-1.1 8.2C9.6 13.3 8 14.8 8 17.2 8 19 9.4 20.5 11.2 20.5c.8 0 1.6-.3 2.2-.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" /><path d="M12 3c-.4 3-.3 5.8 1.1 8.2 1.3 2.1 2.9 3.6 2.9 6 0 1.8-1.4 3.3-3.2 3.3-.8 0-1.6-.3-2.2-.8" stroke="currentColor" stroke-width="1.7" stroke-linecap="round" stroke-linejoin="round" /></svg>
  )
}
{
  name === "person" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="8" r="4" fill="currentColor" /><path d="M4 20c0-4.4 3.6-8 8-8s8 3.6 8 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
  )
}
{
  name === "plus" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="9" stroke="currentColor" stroke-width="2" /><path d="M12 8v8M8 12h8" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
  )
}
{
  name === "circle" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="8" stroke="currentColor" stroke-width="1.6" stroke-dasharray="3 3" /><circle cx="12" cy="4.5" r="2.1" fill="currentColor" /><circle cx="5.4" cy="16.5" r="2.1" fill="currentColor" /><circle cx="18.6" cy="16.5" r="2.1" fill="currentColor" /></svg>
  )
}
{
  name === "chat" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5Z" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" /></svg>
  )
}
{
  name === "close" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M6 6l12 12M18 6L6 18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
  )
}
{
  name === "menu" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><path d="M3 6h18M3 12h18M3 18h18" stroke="currentColor" stroke-width="2" stroke-linecap="round" /></svg>
  )
}
{
  name === "check" && (
    <svg viewBox="0 0 24 24" fill="none" aria-hidden="true"><circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="1.6" /><path d="M8 12.5l2.5 2.5L16 9" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" /></svg>
  )
}
