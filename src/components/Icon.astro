---
import {
  CircleCheck,
  CirclePlus,
  HandHeart,
  Heart,
  Leaf,
  Menu,
  MessageCircle,
  Sparkles,
  UserRound,
  UsersRound,
  X,
} from "@lucide/astro";

type IconName =
  | "heart"
  | "sparkle"
  | "leaf"
  | "person"
  | "plus"
  | "circle"
  | "chat"
  | "close"
  | "menu"
  | "check"
  | "grateful-hands";

interface Props {
  name: IconName;
}

const { name } = Astro.props;

const icons = {
  heart: Heart,
  sparkle: Sparkles,
  leaf: Leaf,
  person: UserRound,
  plus: CirclePlus,
  circle: UsersRound,
  chat: MessageCircle,
  close: X,
  menu: Menu,
  check: CircleCheck,
  "grateful-hands": HandHeart,
} satisfies Record<IconName, typeof Heart>;

const LucideIcon = icons[name];
---

<LucideIcon aria-hidden="true" stroke-width={2} />
