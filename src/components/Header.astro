---
import Icon from "./Icon.astro";
import { navLinks } from "@content/site";
---

<header>
  <div class="wrap nav">
    <a class="logo" href="/" aria-label="Kindr home">kindr<span>.</span></a>
    <nav class="nav-links" aria-label="Primary navigation">
      {navLinks.map((link) => <a class="text-link" href={link.href}>{link.label}</a>)}
      <div class="nav-cta">
        <button class="btn btn-outline" type="button" data-open-modal="giftCardModal">Gift Cards</button>
        <button class="btn btn-primary" type="button" data-calendly>Book with Janet</button>
      </div>
    </nav>
    <button class="menu-toggle" type="button" aria-label="Open menu" data-menu-toggle>
      <Icon name="menu" />
    </button>
  </div>
  <nav class="mobile-nav" aria-label="Mobile navigation" data-mobile-nav hidden>
    {navLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    <a href="javascript:void(0)" data-open-modal="giftCardModal">Gift Cards</a>
    <a href="javascript:void(0)" data-calendly>Book with Janet</a>
  </nav>
</header>
